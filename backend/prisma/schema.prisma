generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// MODELOS DE INGESTÃO VIA CSV (ETL)
// ==========================================

model Lancamento {
  id            String   @id @default(uuid())
  tipo          String   @default("DESPESA") // "RECEITA" ou "DESPESA"
  descricao     String?
  categoria     String?
  centroDeCusto String?
  contaBancaria String?  // p.ex: BB, XP, BTG
  dataPagamento DateTime
  valor         Float
  fornecedor    String?
  createdAt     DateTime @default(now())
}

model ContaReceber {
  id              String   @id @default(uuid())
  cliente         String
  grupo           String?  // Agrupar clientes do mesmo grupo econômico (ex: franquias)
  dataCompetencia DateTime?
  dataVencimento  DateTime
  valor           Float
  status          String   // Vencido, A Vencer, Recebido
  descricao       String?
  numeroNotaFiscal String?
  createdAt       DateTime @default(now())
}

model SaldoBancario {
  id          String   @id @default(uuid())
  instituicao String
  saldo       Float
  data        DateTime
  createdAt   DateTime @default(now())
}

// Armazena tokens OAuth e outras configurações persistentes
model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
