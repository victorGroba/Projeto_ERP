# ============================================================
#  Modelo de variáveis de ambiente — copie para .env e preencha
# ============================================================

# Banco de dados (SQLite). Em Docker é sobrescrito pelo docker-compose
# para apontar ao volume: file:/app/data/prod.db
DATABASE_URL="file:./dev.db"

# Segredo do JWT — GERE UM VALOR FORTE E ÚNICO em produção!
# Ex: openssl rand -hex 32
JWT_SECRET="troque-por-um-segredo-forte-e-aleatorio"

PORT=3001

# Admin inicial (criado só se o banco estiver vazio)
ADMIN_EMAIL="admin@suaempresa.com.br"
ADMIN_PASSWORD="troque-esta-senha"

# ---- Integração Conta Azul (API v2 — app de desenvolvimento) ----
CONTA_AZUL_CLIENT_ID_RJ=""
CONTA_AZUL_CLIENT_SECRET_RJ=""
CONTA_AZUL_REDIRECT_URI="https://contaazul.com"
# Os tokens abaixo são preenchidos automaticamente ao conectar pela
# tela de Configurações. Pode deixar vazio num deploy novo.
CONTA_AZUL_ACCESS_TOKEN_RJ=""
CONTA_AZUL_REFRESH_TOKEN_RJ=""

CONTA_AZUL_CLIENT_ID_SP=""
CONTA_AZUL_CLIENT_SECRET_SP=""
CONTA_AZUL_ACCESS_TOKEN_SP=""
CONTA_AZUL_REFRESH_TOKEN_SP=""
